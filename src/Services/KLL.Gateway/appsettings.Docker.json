{
  "Urls": "http://+:5100",
  "ReverseProxy": {
    "Routes": {
      "store-products": {
        "ClusterId": "store",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}"
        }
      },
      "store-orders": {
        "ClusterId": "store",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      },
      "pay-merchants": {
        "ClusterId": "pay",
        "Match": {
          "Path": "/api/v1/merchants/{**catch-all}"
        }
      },
      "pay-transactions": {
        "ClusterId": "pay",
        "Match": {
          "Path": "/api/v1/transactions/{**catch-all}"
        }
      },
      "pay-webhooks": {
        "ClusterId": "pay",
        "Match": {
          "Path": "/api/v1/webhooks/{**catch-all}"
        }
      },
      "logistics-shipments": {
        "ClusterId": "logistics",
        "Match": {
          "Path": "/api/v1/shipments/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "store": {
        "Destinations": {
          "store-api": {
            "Address": "http://store-api:5200"
          }
        }
      },
      "pay": {
        "Destinations": {
          "pay-api": {
            "Address": "http://pay-api:5300"
          }
        }
      },
      "logistics": {
        "Destinations": {
          "logistics-api": {
            "Address": "http://logistics-api:5400"
          }
        }
      }
    }
  }
}