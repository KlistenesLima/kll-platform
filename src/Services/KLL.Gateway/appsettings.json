{
  "Urls": "http://+:5100",
  "ReverseProxy": {
    "Routes": {
      "store-products": { "ClusterId": "store", "Match": { "Path": "/api/v1/products/{**catch-all}" } },
      "store-orders": { "ClusterId": "store", "Match": { "Path": "/api/v1/orders/{**catch-all}" } },
      "store-cart": { "ClusterId": "store", "Match": { "Path": "/api/v1/cart/{**catch-all}" } },
      "store-categories": { "ClusterId": "store", "Match": { "Path": "/api/v1/categories/{**catch-all}" } },
      "store-upload": { "ClusterId": "store", "Match": { "Path": "/api/v1/upload/{**catch-all}" } },
      "store-shipping": { "ClusterId": "store", "Match": { "Path": "/api/v1/shipping/{**catch-all}" } },
      "store-profile": { "ClusterId": "store", "Match": { "Path": "/api/v1/profile/{**catch-all}" } },
      "store-addresses": { "ClusterId": "store", "Match": { "Path": "/api/v1/addresses/{**catch-all}" } },
      "pay-merchants": { "ClusterId": "pay", "Match": { "Path": "/api/v1/merchants/{**catch-all}" } },
      "pay-transactions": { "ClusterId": "pay", "Match": { "Path": "/api/v1/transactions/{**catch-all}" } },
      "pay-webhooks": { "ClusterId": "pay", "Match": { "Path": "/api/v1/webhooks/{**catch-all}" } },
      "pay-pix": { "ClusterId": "pay", "Match": { "Path": "/api/v1/pay/pix/{**catch-all}" } },
      "pay-health-krt": { "ClusterId": "pay", "Match": { "Path": "/api/v1/pay/health/{**catch-all}" } },
      "logistics-shipments": { "ClusterId": "logistics", "Match": { "Path": "/api/v1/shipments/{**catch-all}" } },
      "store-health": { "ClusterId": "store", "Match": { "Path": "/health/store" }, "Transforms": [ { "PathRemovePrefix": "/health/store" }, { "PathPrefix": "/health" } ] },
      "pay-health": { "ClusterId": "pay", "Match": { "Path": "/health/pay" }, "Transforms": [ { "PathRemovePrefix": "/health/pay" }, { "PathPrefix": "/health" } ] },
      "logistics-health": { "ClusterId": "logistics", "Match": { "Path": "/health/logistics" }, "Transforms": [ { "PathRemovePrefix": "/health/logistics" }, { "PathPrefix": "/health" } ] }
    },
    "Clusters": {
      "store": { "Destinations": { "store-api": { "Address": "http://localhost:5200" } } },
      "pay": { "Destinations": { "pay-api": { "Address": "http://localhost:5300" } } },
      "logistics": { "Destinations": { "logistics-api": { "Address": "http://localhost:5400" } } }
    }
  }
}
