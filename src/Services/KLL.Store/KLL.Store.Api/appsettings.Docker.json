{
  "Urls": "http://+:5200",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=kll_store;Username=kll;Password=CHANGE_ME"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/kll-platform",
    "ValidIssuer": "http://keycloak:8080/realms/kll-platform"
  },
  "Redis": {
    "Connection": "redis:6379"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092"
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": "5672",
    "User": "kll",
    "Password": "CHANGE_ME",
    "VHost": "/"
  },
  "Seq": {
    "Url": "http://seq:5341"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning" } },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://seq:5341" } }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "KrtBank": {
    "BaseUrl": "http://host.docker.internal:5000",
    "WebhookSecret": "${KLL_WEBHOOK_SECRET}"
  },
  "BackblazeB2": {
    "BucketName": "luxestore-media",
    "KeyId": "${B2_KEY_ID}",
    "ApplicationKey": "${B2_APPLICATION_KEY}",
    "Endpoint": "https://s3.us-east-005.backblazeb2.com",
    "PublicUrl": "https://f005.backblazeb2.com/file/luxestore-media"
  },
  "LocalStorage": {
    "BasePath": "/app/products-local"
  }
}