@page "/"

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Inventory" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h5" Class="mt-2">@_productCount</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Products</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Info" Size="Size.Large" />
            <MudText Typo="Typo.h5" Class="mt-2">@_orderCount</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Orders</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.Payment" Color="Color.Success" Size="Size.Large" />
            <MudText Typo="Typo.h5" Class="mt-2">@_transactionCount</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Transactions</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Warning" Size="Size.Large" />
            <MudText Typo="Typo.h5" Class="mt-2">@_shipmentCount</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Shipments</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-4">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">Recent Orders</MudText>
            <MudSimpleTable Dense="true" Hover="true">
                <thead><tr><th>Order ID</th><th>Customer</th><th>Amount</th><th>Status</th></tr></thead>
                <tbody>
                    <tr><td>ORD-001</td><td>João Silva</td><td>R$ 299,90</td><td><MudChip T="string" Color="Color.Success" Size="Size.Small">Paid</MudChip></td></tr>
                    <tr><td>ORD-002</td><td>Maria Santos</td><td>R$ 1.499,00</td><td><MudChip T="string" Color="Color.Warning" Size="Size.Small">Pending</MudChip></td></tr>
                    <tr><td>ORD-003</td><td>Pedro Costa</td><td>R$ 89,90</td><td><MudChip T="string" Color="Color.Info" Size="Size.Small">Shipped</MudChip></td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-3">System Health</MudText>
            <MudSimpleTable Dense="true" Hover="true">
                <thead><tr><th>Service</th><th>Port</th><th>Status</th></tr></thead>
                <tbody>
                    <tr><td>KLL.Store</td><td>5200</td><td><MudChip T="string" Color="Color.Success" Size="Size.Small">Healthy</MudChip></td></tr>
                    <tr><td>KLL.Pay</td><td>5300</td><td><MudChip T="string" Color="Color.Success" Size="Size.Small">Healthy</MudChip></td></tr>
                    <tr><td>KLL.Logistics</td><td>5400</td><td><MudChip T="string" Color="Color.Success" Size="Size.Small">Healthy</MudChip></td></tr>
                    <tr><td>KLL.Gateway</td><td>5100</td><td><MudChip T="string" Color="Color.Success" Size="Size.Small">Healthy</MudChip></td></tr>
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private int _productCount = 156;
    private int _orderCount = 43;
    private int _transactionCount = 89;
    private int _shipmentCount = 37;
}