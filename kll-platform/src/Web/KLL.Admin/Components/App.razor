@using MudBlazor

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-3">KLL Platform Admin</MudText>
        <MudSpacer />
        <MudChip T="string" Color="Color.Success" Size="Size.Small">v1.0</MudChip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavGroup Title="Store" Icon="@Icons.Material.Filled.Store" Expanded="true">
                <MudNavLink Href="/products" Icon="@Icons.Material.Filled.Inventory">Products</MudNavLink>
                <MudNavLink Href="/orders" Icon="@Icons.Material.Filled.ShoppingCart">Orders</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Payments" Icon="@Icons.Material.Filled.Payment">
                <MudNavLink Href="/merchants" Icon="@Icons.Material.Filled.Business">Merchants</MudNavLink>
                <MudNavLink Href="/transactions" Icon="@Icons.Material.Filled.Receipt">Transactions</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Logistics" Icon="@Icons.Material.Filled.LocalShipping">
                <MudNavLink Href="/shipments" Icon="@Icons.Material.Filled.Inventory2">Shipments</MudNavLink>
                <MudNavLink Href="/drivers" Icon="@Icons.Material.Filled.DirectionsCar">Drivers</MudNavLink>
            </MudNavGroup>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-16 px-4">
        <Microsoft.AspNetCore.Components.Routing.Router AppAssembly="@typeof(App).Assembly">
            <Found Context="routeData">
                <Microsoft.AspNetCore.Components.RouteView RouteData="@routeData" />
            </Found>
            <NotFound>
                <MudText Typo="Typo.h5">Page not found</MudText>
            </NotFound>
        </Microsoft.AspNetCore.Components.Routing.Router>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#FF6F00",
            AppbarBackground = "#1976D2"
        }
    };
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}