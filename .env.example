# KLL Platform — Production Environment Variables
# Copy this file to .env and fill in your values

# ==================== PostgreSQL ====================
POSTGRES_USER=kll
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=kll_store

# ==================== Keycloak ====================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK_PASSWORD

# ==================== RabbitMQ ====================
RABBITMQ_DEFAULT_USER=kll
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBITMQ_PASSWORD

# ==================== Seq ====================
SEQ_ADMIN_PASSWORD=CHANGE_ME_SEQ_PASSWORD

# ==================== Redis (optional) ====================
# KLL_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ==================== KRT Bank Integration ====================
KRT_API_KEY=CHANGE_ME_MUST_MATCH_KRT_BANK
KRT_BANK_URL=http://host.docker.internal:5000

# ==================== Webhook Secret ====================
KLL_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ==================== Backblaze B2 (Product Images) ====================
B2_KEY_ID=CHANGE_ME_B2_KEY_ID
B2_APPLICATION_KEY=CHANGE_ME_B2_APPLICATION_KEY

# ==================== SMTP (Email Service) ====================
SMTP_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD

# ==================== CORS (optional — defaults baked into code) ====================
# ALLOWED_ORIGINS=https://store.klisteneslima.dev,https://admin.klisteneslima.dev

# ==================== Environment ====================
ASPNETCORE_ENVIRONMENT=Docker
